{
	"name": "github-pr-linker",
	"version": "1.0.0",
	"description": "Obsidian plugin that turns GitHub pull request references into Markdown links",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"github"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^26.1.1",
		"esbuild": "0.28.1",
		"obsidian": "latest",
		"typescript": "^7.0.2",
		"vitest": "^3.2.4"
	}
}
